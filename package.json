{
  "name": "web-printer",
  "version": "1.0.0",
  "description": "Web UI for sharing printers from a remote CUPS server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "smoke": "node scripts/smoke-test.mjs",
    "test": "npm run smoke",
    "precommit": "node scripts/pre-commit-checks.mjs",
    "prepare": "node -e \"const fs=require('node:fs');const path=require('node:path');const cp=require('node:child_process');const bin=path.join(process.cwd(),'node_modules','.bin',process.platform==='win32'?'husky.cmd':'husky');if(!fs.existsSync(bin))process.exit(0);const r=cp.spawnSync(bin,{stdio:'inherit'});if(r.error)throw r.error;process.exit(r.status??0);\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luojiyin1987/web-printer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/luojiyin1987/web-printer/issues"
  },
  "homepage": "https://github.com/luojiyin1987/web-printer#readme",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ipp": "^2.0.1",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "yaml": "^2.8.3"
  }
}
